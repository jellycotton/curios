{
  "manifest_version": 3,
  "name": "Curios",
  "version": "0.1.0",
  "description": "選択したテキストを右クリックして、リアルタイムでファクトチェックします。",
  "permissions": [
    "contextMenus",
    "scripting",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["Curios.png"],
      "matches": ["<all_urls>"]
    }
  ]
}